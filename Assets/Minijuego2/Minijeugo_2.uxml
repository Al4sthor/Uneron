        <ui:VisualElement name="Faltan_Partes" class="contenedor_Faltan_Partes" style="background-image: url(&quot;project://database/Assets/Minijuego2/Faltan_Partes.png?fileID=2800000&amp;guid=fd17816e088e9cd49987dd6299280a68&amp;type=3#Faltan_Partes&quot;);"/>
